# ============================================
# FERTILITY FL PROJECT .gitignore
# ============================================

# ============================================
# DATA FILES (Large, sensitive)
# ============================================
data/
data/raw/
data/processed/
*.csv
*.npy
*.pkl
*.arrow

# ============================================
# PYTHON
# ============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
.venv/
venv/
ENV/
env/
*.venv

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# ============================================
# MACHINE LEARNING
# ============================================
# Model checkpoints
checkpoints/
models/
*.pth
*.h5
*.hdf5
*.ckpt
*.safetensors

# Experiment outputs
results/
outputs/
runs/
logs/
*.log

# Tensorboard
events.out.tfevents.*

# Weights & Biases
wandb/

# MLflow
mlruns/

# ============================================
# FEDERATED LEARNING SPECIFIC
# ============================================
# Ray temporary files
/tmp/ray/
ray_results/

# Flower outputs
.flwr/
flwr_logs/

# ============================================
# IDE / EDITOR
# ============================================
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ============================================
# OPERATING SYSTEM
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ============================================
# DOCUMENTATION (Optional - keep if you want)
# ============================================
# Uncomment if you don't want to version docs
# docs/_build/
# docs/*.pdf

# ============================================
# MISCELLANEOUS
# ============================================
# Environment variables
.env
.env.local
*.env

# Secrets
secrets/
*.key
*.pem

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# Compressed files (if not needed)
*.zip
*.tar.gz
*.rar

# ============================================
# PROJECT SPECIFIC
# ============================================
# Large experiment files
experiments/
archived/

# Personal notes (if you have any)
notes.txt
todo.txt
scratch/